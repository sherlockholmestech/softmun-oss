APP_ENV=staging
SOFTMUN_DB_TARGET=staging
NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
NUXT_NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
ALLOW_PROD_DB_WRITE=false

# Optional invite-code allowlist for sign up. Comma-separated.
# When set, /auth/signup requires one of the codes.
# Leave empty or unset to allow open sign up.
# NUXT_SIGNUP_INVITE_CODES=alpha,bravo,charlie
